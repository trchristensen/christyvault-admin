{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "althinect/filament-spatie-roles-permissions": "^3.0",
        "barryvdh/laravel-snappy": "^1.0",
        "calebporzio/sushi": "^2.5",
        "endroid/qr-code": "^6.0",
        "filament/filament": "^5.0",
        "flowframe/laravel-trend": "^0.4.0",
        "h4cc/wkhtmltopdf-amd64": "0.12.x",
        "jeffgreco13/filament-breezy": ">=3.1 <3.2",
        "laravel/framework": "12.63.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.29",
        "opcodesio/log-viewer": "^3.12",
        "resend/resend-laravel": "^1.4",
        "resend/resend-php": "^1.4",
        "saade/filament-fullcalendar": "^4.0",
        "schmeits/filament-character-counter": "^5.0",
        "setasign/fpdf": "^1.8",
        "setasign/fpdi": "^2.6",
        "spatie/icalendar-generator": "~2.8.0",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-backup": "^9.1",
        "spatie/pdf-to-image": "^1.2",
        "spatie/pdf-to-text": "^1.54",
        "spykapps/filament-passwordless-login": "^1.0",
        "telnyx/telnyx-php": "^3.0",
        "thiagoalessio/tesseract_ocr": "^2.13",
        "ysfkaya/filament-phone-input": "^4.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^3.2",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
